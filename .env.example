# =============================================================================
# L'Olympus — environment configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the placeholder values. `.env` is
# gitignored; `.env.example` is the canonical reference that ships with the
# repo. The most common edits are under "Model tiers" below.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM PROVIDER
# -----------------------------------------------------------------------------
# Which provider serves models that don't explicitly override it.
# Supported values:
#   openrouter     (recommended — BYOK unlocks nearly every major model)
#   openai-compat  (OpenAI, vLLM, Ollama, LM Studio, TGI, LiteLLM, Azure,
#                   Groq, Together, Fireworks, DeepInfra, any OpenAI-shaped API)
#   anthropic      (direct Anthropic, non-OpenRouter path)
#   google         (direct Gemini)
#   mock           (deterministic fixtures — offline demos, tests)
LLM_PROVIDER=openrouter


# --- OpenRouter (default) ----------------------------------------------------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Sent as OpenRouter attribution headers (optional but helps you track usage)
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=Olympus


# --- OpenAI-compatible (self-hosted, OpenAI, Ollama, etc.) -------------------
# Only set these if you plan to use LLM_PROVIDER=openai-compat, or if a
# ROLE_MODEL_* / MODEL_TIER_* entry explicitly selects openai-compat.
# Example for local Ollama:
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_API_KEY=ollama
OPENAI_BASE_URL=
OPENAI_API_KEY=


# --- Anthropic (direct, optional) --------------------------------------------
ANTHROPIC_API_KEY=


# --- Google Gemini (direct, optional) ----------------------------------------
GOOGLE_API_KEY=


# =============================================================================
# MODEL TIERS
# -----------------------------------------------------------------------------
# Agents are routed by *task complexity*, not role. Four tiers total.
# Each value is either:
#   <model>                 — uses LLM_PROVIDER above
#   <provider>:<model>      — overrides the provider just for this tier
#
# Tiers:
#   FAST       — quick, bounded tasks: reviewer notes, writer prose,
#                status summaries, parsing, ticket CRUD, log triage
#   REASONING  — deep planning & multi-step thinking: Orchestrator, PM,
#                Architect, Tech Lead, Security, Incident classification
#   CODING     — code generation, edits, refactors, test writing:
#                Backend Dev, Frontend Dev, DevOps scripts
#   VISION     — multimodal: QA screenshot understanding, mockup ingestion
# =============================================================================
MODEL_TIER_FAST=openai/gpt-5-mini
MODEL_TIER_REASONING=anthropic/claude-sonnet-4
MODEL_TIER_CODING=anthropic/claude-sonnet-4
MODEL_TIER_VISION=google/gemini-2.5-pro


# -----------------------------------------------------------------------------
# ROLE OVERRIDES (optional)
# -----------------------------------------------------------------------------
# Most users never touch these — the default role→tier mapping is sensible.
# Uncomment to override a specific role. Each value may be:
#   tier:<fast|reasoning|coding|vision>
#   <model>                 — uses LLM_PROVIDER
#   <provider>:<model>      — full override
# -----------------------------------------------------------------------------
# ROLE_MODEL_ORCHESTRATOR=tier:reasoning
# ROLE_MODEL_PM=tier:reasoning
# ROLE_MODEL_ARCHITECT=openai/gpt-5
# ROLE_MODEL_TECHLEAD=tier:reasoning
# ROLE_MODEL_BACKEND_DEV=tier:coding
# ROLE_MODEL_FRONTEND_DEV=tier:coding
# ROLE_MODEL_DEVOPS=tier:coding
# ROLE_MODEL_QA=tier:vision
# ROLE_MODEL_REVIEWER=tier:fast
# ROLE_MODEL_SECURITY=tier:reasoning
# ROLE_MODEL_INCIDENT=tier:reasoning
# ROLE_MODEL_RELEASE=tier:fast
# ROLE_MODEL_WRITER=tier:fast


# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_USER=olympus
POSTGRES_PASSWORD=olympus_dev
POSTGRES_DB=olympus
POSTGRES_PORT=5432
DATABASE_URL=postgres://olympus:olympus_dev@localhost:5432/olympus


# =============================================================================
# APP
# =============================================================================
OLYMPUS_HOST=0.0.0.0
OLYMPUS_WEB_PORT=3000
OLYMPUS_ORCH_PORT=4000
OLYMPUS_WORKSPACES_DIR=./workspaces
OLYMPUS_LOG_LEVEL=info
# Auto-generated on first boot if left blank
OLYMPUS_SESSION_SECRET=


# =============================================================================
# BUDGETS (defaults per project; can be overridden in-app per project)
# =============================================================================
# Soft caps pause the pipeline and require human approval to continue.
# Hard caps halt the pipeline outright.
BUDGET_TOKENS_SOFT=2000000
BUDGET_TOKENS_HARD=5000000
BUDGET_USD_SOFT=10
BUDGET_USD_HARD=25
BUDGET_WALLCLOCK_MINUTES=180
BUDGET_HEAL_ATTEMPTS_PER_INCIDENT=3
BUDGET_INCIDENTS_PER_BUILD=10
# Max dev+reviewer attempts per ticket before the IMPLEMENT loop gives up and
# writes HELP_NEEDED.md. Raise this if reviewers tend to request changes more
# than a couple of times before approving.
BUDGET_IMPLEMENT_ATTEMPTS_PER_TICKET=6


# =============================================================================
# RUNNER (Docker sandbox for build / test / serve / QA)
# =============================================================================
DOCKER_HOST=unix:///var/run/docker.sock
RUNNER_MEMORY_LIMIT=2g
RUNNER_CPUS=2


# =============================================================================
# BROWSER (QA via Playwright)
# =============================================================================
PLAYWRIGHT_HEADLESS=true


# =============================================================================
# TELEMETRY
# =============================================================================
# Set to 1 to opt into anonymous usage stats. Off by default. Never sends
# project contents, prompts, keys, or artifacts — only aggregate counters.
OLYMPUS_TELEMETRY=0
