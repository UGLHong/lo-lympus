# LLM Provider Configuration
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:3100
OPENROUTER_APP_TITLE=Olympus

# Model Tiers
MODEL_TIER_FAST=openai/gpt-oss-20b:free
MODEL_TIER_REASONING=openai/gpt-oss-120b:free
MODEL_TIER_CODING=openai/gpt-oss-20b:free
MODEL_TIER_VISION=openai/gpt-oss-120b:free
MODEL_TIER_COMPLEX=anthropic/claude-opus-4
MODEL_TIER_PLANNING=openai/o1

# Local development database (requires: docker-compose up)
DATABASE_URL=postgresql://devuser:devpass@localhost:5432/lolympus_dev

# For production, use the DigitalOcean database:
# DATABASE_URL=postgresql://doadmin:password@jomini-enterprise-db-do-user-xxx.b.db.ondigitalocean.com:25060/lolympus_prod?sslmode=require

# Server Configuration
OLYMPUS_HOST=0.0.0.0
OLYMPUS_WEB_PORT=3100
OLYMPUS_WORKSPACES_DIR=./workspaces
OLYMPUS_LOG_LEVEL=info

# Token Budget
BUDGET_TOKENS_SOFT=2000000
BUDGET_TOKENS_HARD=5000000
BUDGET_WALLCLOCK_MINUTES=180

# Worker Configuration
OLYMPUS_PHASE_IDLE_BUFFER_MS=15000
OLYMPUS_SUPERVISOR_TICK_MS=1000
OLYMPUS_EMPLOYEE_POLL_MS=5000
OLYMPUS_EMPLOYEE_CONFIG_DIR=./config/employees
OLYMPUS_WORKER_POLL_MS=400

# Web Search (Optional)
# TAVILY_API_KEY=your_api_key_here
# SERPAPI_API_KEY=your_api_key_here
